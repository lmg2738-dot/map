# LandScout — Vercel 환경변수 (서버 전용, NEXT_PUBLIC_ 사용 금지)
# Vercel Dashboard → Settings → Environment Variables 에 등록
# .env.local 은 .gitignore 에 포함 — 값은 절대 Git에 커밋하지 마세요.

# ── 지형 · 지적도 · 정사영상 ───────────────────
VWORLD_API_KEY=
NGII_API_KEY=

# ── 주소 검색 · POI ───────────────────────────
KAKAO_REST_API_KEY=

# ── AI 분석 (OpenRouter, 무료 모델 자동 선택) ──
OPENROUTER_API_KEY=

# ── 선택 (OpenRouter 앱 식별용) ────────────────
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=LandScout
