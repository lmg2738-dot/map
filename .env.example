# LandScout — Vercel 환경변수 (서버 전용, NEXT_PUBLIC_ 사용 금지)
# Vercel Dashboard → Settings → Environment Variables 에 등록
# .env.local 은 .gitignore 에 포함되어야 합니다.

# ── 주소 · 좌표 ──────────────────────────────────
JUSO_API_KEY=

# ── 지형 · 지적도 · 정사영상 ───────────────────
VWORLD_API_KEY=
NGII_API_KEY=

# ── 진입로 · POI ───────────────────────────────
TMAP_API_KEY=
KAKAO_REST_API_KEY=

# ── AI 분석 (OpenRouter) ───────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
